<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="org.example.gui.HelloController"
      spacing="8"
      style="-fx-padding: 8;">

    <GridPane hgap="16" vgap="4">
        <Label text="Community Pool" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
        <Label fx:id="communityPoolLabel" text="-% used" GridPane.columnIndex="1" GridPane.rowIndex="0"/>

        <Label text="Grid Portion" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
        <Label fx:id="gridPortionLabel" text="-%" GridPane.columnIndex="1" GridPane.rowIndex="1"/>
    </GridPane>

    <Button text="refresh" onAction="#onRefreshClick"/>

    <GridPane hgap="6" vgap="4">
        <Label text="Start" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
        <DatePicker fx:id="startDatePicker" prefWidth="130" GridPane.columnIndex="1" GridPane.rowIndex="0"/>
        <Spinner fx:id="startHourSpinner" prefWidth="70" GridPane.columnIndex="2" GridPane.rowIndex="0"/>
        <Label text=":" GridPane.columnIndex="3" GridPane.rowIndex="0"/>
        <Spinner fx:id="startMinuteSpinner" prefWidth="70" GridPane.columnIndex="4" GridPane.rowIndex="0"/>

        <Label text="End" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
        <DatePicker fx:id="endDatePicker" prefWidth="130" GridPane.columnIndex="1" GridPane.rowIndex="1"/>
        <Spinner fx:id="endHourSpinner" prefWidth="70" GridPane.columnIndex="2" GridPane.rowIndex="1"/>
        <Label text=":" GridPane.columnIndex="3" GridPane.rowIndex="1"/>
        <Spinner fx:id="endMinuteSpinner" prefWidth="70" GridPane.columnIndex="4" GridPane.rowIndex="1"/>
    </GridPane>

    <Button text="show data" onAction="#onShowDataClick"/>

    <GridPane hgap="16" vgap="4">
        <Label text="Community produced" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
        <Label fx:id="communityProducedLabel" text="- kWh" GridPane.columnIndex="1" GridPane.rowIndex="0"/>

        <Label text="Community used" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
        <Label fx:id="communityUsedLabel" text="- kWh" GridPane.columnIndex="1" GridPane.rowIndex="1"/>

        <Label text="Grid used" GridPane.columnIndex="0" GridPane.rowIndex="2"/>
        <Label fx:id="gridUsedLabel" text="- kWh" GridPane.columnIndex="1" GridPane.rowIndex="2"/>
    </GridPane>
</VBox>
