<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns:fx="http://javafx.com/fxml" fx:controller="org.example.gui.HelloController" spacing="10.0" style="-fx-padding: 15;">

    <!-- Community Pool Section -->
    <VBox style="-fx-border-color: #000000; -fx-border-width: 2; -fx-padding: 10;">
        <GridPane hgap="20.0" vgap="5.0">
            <Label text="Community Pool" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
            <Label fx:id="communityPoolLabel" text="78.54% used" GridPane.columnIndex="1" GridPane.rowIndex="0"/>
            <Label text="Grid Portion" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
            <Label fx:id="gridPortionLabel" text="7.23%" GridPane.columnIndex="1" GridPane.rowIndex="1"/>
        </GridPane>
    </VBox>

    <!-- Refresh Button -->
    <Button text="refresh" style="-fx-padding: 6 15; -fx-font-size: 11;" onAction="#onRefreshClick"/>

    <!-- Date/Time Selection -->
    <GridPane hgap="10.0" vgap="8.0">
        <Label text="Start" GridPane.columnIndex="0" GridPane.rowIndex="0" style="-fx-min-width: 40;"/>
        <DatePicker fx:id="startDatePicker" prefWidth="130.0" GridPane.columnIndex="1" GridPane.rowIndex="0"/>
        <Spinner fx:id="startHourSpinner" prefWidth="70.0" GridPane.columnIndex="2" GridPane.rowIndex="0"/>
        <Label text=":" GridPane.columnIndex="3" GridPane.rowIndex="0" style="-fx-text-alignment: center; -fx-min-width: 15;"/>
        <Spinner fx:id="startMinuteSpinner" prefWidth="70.0" GridPane.columnIndex="4" GridPane.rowIndex="0"/>

        <Label text="End" GridPane.columnIndex="0" GridPane.rowIndex="1" style="-fx-min-width: 40;"/>
        <DatePicker fx:id="endDatePicker" prefWidth="130.0" GridPane.columnIndex="1" GridPane.rowIndex="1"/>
        <Spinner fx:id="endHourSpinner" prefWidth="70.0" GridPane.columnIndex="2" GridPane.rowIndex="1"/>
        <Label text=":" GridPane.columnIndex="3" GridPane.rowIndex="1" style="-fx-text-alignment: center; -fx-min-width: 15;"/>
        <Spinner fx:id="endMinuteSpinner" prefWidth="70.0" GridPane.columnIndex="4" GridPane.rowIndex="1"/>
    </GridPane>

    <!-- Show Data Button -->
    <Button text="show data" style="-fx-padding: 6 15; -fx-font-size: 11;" onAction="#onShowDataClick"/>

    <!-- Data Display Section -->
    <VBox style="-fx-border-color: #000000; -fx-border-width: 2; -fx-padding: 10;">
        <GridPane hgap="20.0" vgap="5.0">
            <Label text="Community produced" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
            <Label fx:id="communityProducedLabel" text="143.024 kWh" GridPane.columnIndex="1" GridPane.rowIndex="0"/>
            <Label text="Community used" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
            <Label fx:id="communityUsedLabel" text="130.101 kWh" GridPane.columnIndex="1" GridPane.rowIndex="1"/>
            <Label text="Grid used" GridPane.columnIndex="0" GridPane.rowIndex="2"/>
            <Label fx:id="gridUsedLabel" text="14.75 kWh" GridPane.columnIndex="1" GridPane.rowIndex="2"/>
        </GridPane>
    </VBox>

</VBox>
